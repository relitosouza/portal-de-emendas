# Autenticação do admin (obrigatório)
ADMIN_EMAIL="admin@osasco.sp.gov.br"
ADMIN_PASSWORD="sua-senha-segura"
ADMIN_SESSION_SECRET="string-aleatoria-longa-para-assinar-tokens"

# Segredo para autenticação do cron de sincronização (obrigatório em produção)
CRON_SECRET="string-aleatoria-para-proteger-endpoint-de-sync"

# PostgreSQL — banco de dados principal (obrigatório em produção)
# Formato: postgresql://usuario:senha@host:5432/nome_banco
DATABASE_URL="postgresql://portal_user:senha@localhost:5432/portal_emendas"

# Habilitar SSL na conexão com o banco (opcional, use "true" se o servidor exigir)
DATABASE_SSL="false"

# Google Sheets (opcional — sistema funciona sem isso)
GOOGLE_SERVICE_ACCOUNT_EMAIL="conta@projeto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="id-da-planilha"

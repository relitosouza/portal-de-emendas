# Autenticação do admin (obrigatório)
ADMIN_EMAIL="admin@osasco.sp.gov.br"
ADMIN_PASSWORD="senha-exclusiva-com-pelo-menos-16-caracteres"
ADMIN_SESSION_SECRET="segredo-aleatorio-com-pelo-menos-32-caracteres"

# Google Sheets (opcional — sistema funciona sem isso)
GOOGLE_SERVICE_ACCOUNT_EMAIL="conta@projeto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="id-da-planilha"

# Redis (obrigatório em produção)
# Obtida no Redis Cloud: dashboard → banco → Connect → redis-cli URL
REDIS_URL="redis://default:<senha>@<host>:<porta>"

# URL pública usada em canonical, Open Graph, robots.txt e sitemap.xml.
NEXT_PUBLIC_SITE_URL="https://portal-de-emendas.vercel.app"

# Segredo gerado automaticamente pela Vercel para autenticar o cron.
# Também pode ser definido manualmente com uma string aleatória longa.
CRON_SECRET="outro-segredo-aleatorio-com-pelo-menos-32-caracteres"
